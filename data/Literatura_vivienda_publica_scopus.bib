	year = {2021},
	journal = {PLoS ONE},
	volume = {16},
	number = {8 August},
	doi = {10.1371/journal.pone.0253591},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85113304984&doi=10.1371%2fjournal.pone.0253591&partnerID=40&md5=9e079b3de1f6b603d0529f9ef33356b5},
	affiliations = {Carl Zeiss GmbH, Vienna, Austria; Department of Geography and Anthropology, Louisiana State University, Baton Rouge, LA, United States; Infineon Technologies IT-Services GmbH, Villach, Austria},
	abstract = {This research compares and evaluates different approaches to approximate offense times of crimes. It contributes to and extends all previously proposed naïve and aoristic temporal approximation methods and one recent study [1] that showed that the addition of historical crimes with accurately known time stamps to temporal approximation methods can outperform all traditional approximation methods. It is paramount to work with crime data that possess precise temporal information to conduct reliable (spatiotemporal) analysis and modeling. This study contributes to and extends existing studies on temporal analysis. One novel and one relatively new temporal approximation methods are introduced that rely on weighting aoristic scores with historic offenses with exactly known offense times. It is hypothesized that these methods enhance the accuracy of the temporal approximation. In total, eight different methods are evaluated for apartment burglaries in Vienna, Austria, for yearly and seasonal differences. Results show that the one novel and one relatively new method applied in this research outperform all other existing approximation methods to estimate and predict offense times. These two methods are particularly useful for both researchers and practitioners, who often work with temporally imprecise crime data. Copyright: © 2021 Glasner et al. This is an open access article distributed under the terms of the Creative Commons Attribution License, which permits unrestricted use, distribution, and reproduction in any medium, provided the original author and source are credited.},
	keywords = {Austria; Crime; Housing; Humans; Seasons; Theft; Time Factors; article; Austria; burglary; comparative study; controlled study; human; physician; spatiotemporal analysis; Austria; comparative study; crime; housing; season; theft; time factor},
	correspondence_address = {M. Leitner; Department of Geography and Anthropology, Louisiana State University, Baton Rouge, United States; email: mleitne@lsu.edu},
	publisher = {Public Library of Science},
	issn = {19326203},
	coden = {POLNC},
	pmid = {34411128},
	language = {English},
	abbrev_source_title = {PLoS ONE},
	type = {Article},
