	year = {2024},
	journal = {Housing Studies},
	volume = {39},
	number = {7},
	pages = {1607 – 1631},
	doi = {10.1080/02673037.2022.2135170},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85141627376&doi=10.1080%2f02673037.2022.2135170&partnerID=40&md5=0424f4c6e478101c414918a9401500e4},
	affiliations = {Department of Public Finance and Infrastructure Policy, Institute of Spatial Planning, TU Wien, Wien, Austria; Department of Architecture, Aalto University, Aalto, Finland},
	abstract = {The supply of social housing has been marked by erosion and decline in most Western Europe countries since the 1990s, albeit with considerable variation in timing, speed and degree. Recently, it has been suggested that the sector has kept a more prominent position at the local level, at least in some cities. This paper scrutinizes this claim by comparing the development of social housing in two cities in two distinct national housing systems that have traditionally had a strong commitment to social housing: Vienna and Helsinki. To do so, we build a multi-dimensional framework that encompasses sector size, stock privatization, new housing production, and residualization. We empirically demonstrate a remarkable stability along these dimensions in both cases, albeit with some differences in degree. A number of factors need to be considered to explain this stability. They relate to aspects of institutional design of the social housing systems, as well as to continuity in policies at national and local levels. © 2022 The Author(s). Published by Informa UK Limited, trading as Taylor & Francis Group.},
	author_keywords = {Austria; Comparative housing research; Finland; privatization; residualization; urban housing systems},
	keywords = {Austria; Finland; Helsinki; Varsinais-Suomi; Vienna; comparative study; housing conditions; housing provision; institutional framework; social housing},
