	year = {2021},
	journal = {European Urban and Regional Studies},
	volume = {28},
	number = {4},
	pages = {353 – 374},
	doi = {10.1177/09697764211003626},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85105016767&doi=10.1177%2f09697764211003626&partnerID=40&md5=87aea80df87eefeaa868f05877901970},
	affiliations = {Vienna University of Technology, Austria; Bauhaus-Universität Weimar, Germany; City University of New York, United States},
	abstract = {In cities worldwide, the housing question has returned. As demands and proposals by housing movements have grown bolder, city governments are implementing new policies, ranging from small tweaks to major overhauls. This paper takes a close look at New York City, Berlin and Vienna, assessing their current housing policy landscapes. We evaluate to what extent those cities’ recent housing reforms depart from the dominant, neoliberal policy landscape of recent decades and can be categorized as ‘post-neoliberal’. We do so through the criteria of affordability, decommodification and democratization. The three selected cities display varying histories of housing systems and neoliberalization, enabling us to search for post-neoliberal policies in three distinct institutional contexts. We find a common pattern across cases: recent reforms have improved affordability and dampened hyper-commodification, but little has been done to address the democratization of housing and planning systems. By way of conclusion, we discuss some of the structural factors that impede attempts at developing a genuinely post-neoliberal transformation of local housing policies. © The Author(s) 2021.},
	author_keywords = {Berlin; housing policy; New York; policy analysis; post-neoliberalism; Vienna},
	keywords = {Austria; Berlin; Germany; New York [New York (STT)]; New York [United States]; United States; Vienna; affordable housing; housing policy; housing provision; housing reform; liberalization; neoliberalism; policy analysis},
